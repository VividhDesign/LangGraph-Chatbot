# Copy this file to .env and fill in your actual API keys
# Never commit .env to GitHub — this .env.example is safe to commit

# Get your Google AI API key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: LangSmith tracing (for debugging your LangGraph graph)
# Get it from: https://smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=LangGraph_Chatbot
LANGCHAIN_TRACING_V2=true
